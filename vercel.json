{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    { "path": "/api/sync", "schedule": "0 */3 * * *" }
  ],
  "rewrites": [
    { "source": "/((?!api/|assets/|favicon).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/property-real/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    }
  ]
}
