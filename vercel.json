{
  "buildCommand": null,
  "outputDirectory": ".",
  "installCommand": null,
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/dashboard",
      "destination": "/admin/dashboard",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/guest-portal",
      "destination": "/guest-portal.html"
    },
    {
      "source": "/cinematic",
      "destination": "/cinematic.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/sync-bookings-to-odoo",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/sync-icals",
      "schedule": "*/10 * * * *"
    }
  ]
}