# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# MyFatoorah Payment Gateway
# Keep Test and Live credentials separate. MYFATOORAH_ENV controls which one is read server-side.
MYFATOORAH_ENV=test
MYFATOORAH_TEST_API_KEY=your_myfatoorah_test_api_key_here
MYFATOORAH_API_KEY=your_myfatoorah_saudi_live_api_key_here
MYFATOORAH_WEBHOOK_SECRET=your_myfatoorah_webhook_v2_secret_here

# Application URLs
NEXT_PUBLIC_APP_URL=https://horizonstays.com
CRON_SECRET=your_cron_secret_here

# TTLock Smart Lock Integration (Optional)
TTLOCK_CLIENT_ID=your_ttlock_client_id_here
TTLOCK_CLIENT_SECRET=your_ttlock_client_secret_here

# WozTell WhatsApp Integration (Optional)
WOZTELL_API_KEY=your_woztell_api_key_here
WOZTELL_PHONE_NUMBER_ID=your_woztell_phone_number_id_here

# Odoo ERP Integration (Optional)
ODOO_URL=your_odoo_instance_url_here
ODOO_DB=your_odoo_database_name_here
ODOO_USERNAME=your_odoo_username_here
ODOO_PASSWORD=your_odoo_password_here
