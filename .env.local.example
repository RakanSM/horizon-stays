# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# MyFatoorah
MYFATOORAH_API_KEY=
MYFATOORAH_ENV=test

# Odoo
ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_API_KEY=

# WozTell
WOZTELL_API_KEY=
WOZTELL_PHONE_NUMBER_ID=

# TTLock
TTLOCK_CLIENT_ID=
TTLOCK_CLIENT_SECRET=

# Booking Platforms
AIRBNB_WEBHOOK_SECRET=
BOOKING_CHANNEL_MANAGER_KEY=
GATHERIN_API_KEY=
EXPEDIA_API_KEY=
EXPEDIA_API_SECRET=

# App
NEXT_PUBLIC_APP_URL=https://horizonstays.com
NEXTAUTH_SECRET=

# ── iCal Sync (Free Channel Manager) ──────────────────────────
# Paste each platform's exported iCal URL per property
# Format: ICAL_{PROPERTY_ID}_{PLATFORM} where platform = AIRBNB | BOOKING | GATHERIN | EXPEDIA
# Example:
# ICAL_1_AIRBNB=https://www.airbnb.com/calendar/ical/1213854045018637530.ics?s=xxxxx
# ICAL_1_BOOKING=https://ical.booking.com/v1/export?t=xxxxx
# ... repeat for all 16 properties × 4 platforms

# ── Email Lock (Instant Airbnb date block) ─────────────────────
EMAIL_ADDRESS=yourhost@gmail.com
EMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ── Cron Security ──────────────────────────────────────────────
CRON_SECRET=generate_a_random_secret_here
